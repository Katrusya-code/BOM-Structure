<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Assembly Reference Tool</title>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #f5f2ee;
    --bg2:       #ede9e3;
    --surface:   #ffffff;
    --surface2:  #faf8f5;
    --border:    #e0dbd3;
    --border2:   #d0c9be;
    --accent:    #2563eb;
    --accent-lt: #dbeafe;
    --accent-mid:#93c5fd;
    --text:      #1a1714;
    --text-dim:  #5c5549;
    --text-muted:#9c9389;
    --green:     #059669;
    --green-lt:  #d1fae5;
    --amber:     #b45309;
    --amber-lt:  #fef3c7;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.05);
    --shadow-lg: 0 8px 32px rgba(0,0,0,0.1), 0 4px 12px rgba(0,0,0,0.06);
    --radius:    12px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Instrument Sans', sans-serif;
    min-height: 100vh;
    background-image: 
      radial-gradient(circle at 20% 10%, rgba(219,234,254,0.4) 0%, transparent 50%),
      radial-gradient(circle at 80% 90%, rgba(209,250,229,0.25) 0%, transparent 50%);
  }

  /* NAV */
  .nav {
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 32px;
    height: 72px;
    display: flex;
    align-items: center;
    gap: 16px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 1px 0 var(--border), 0 4px 16px rgba(0,0,0,0.04);
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    cursor: pointer;
    flex-shrink: 0;
  }
  .nav-brand-icon {
    width: 36px; height: 36px;
    background: var(--accent);
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 10px rgba(37,99,235,0.35);
  }
  .nav-brand-icon svg { color: white; }
  .nav-brand-text {
    font-family: 'Lora', serif;
    font-size: 17px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .nav-brand-text em {
    font-style: italic;
    color: var(--accent);
  }

  .nav-divider {
    width: 1px;
    height: 28px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* Home tab — always visible, prominent */
  .nav-home-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface2);
    border: 1.5px solid var(--border);
    color: var(--text-dim);
    padding: 10px 20px;
    border-radius: 10px;
    cursor: pointer;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    box-shadow: var(--shadow-sm);
    transition: all 0.2s;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .nav-home-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-lt);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }
  .nav-home-btn.active-tab {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
    box-shadow: 0 2px 10px rgba(37,99,235,0.3);
  }
  .nav-home-btn.active-tab:hover {
    background: #1d4ed8;
    border-color: #1d4ed8;
    color: white;
    box-shadow: 0 4px 14px rgba(37,99,235,0.4);
  }

  /* Search — takes remaining space, very prominent */
  .nav-search-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .nav-search-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--text-muted);
    padding-left: 2px;
  }
  .nav-center {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 12px;
    padding: 11px 18px;
    width: 100%;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .nav-center:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(37,99,235,0.1), var(--shadow-sm);
  }
  .nav-center .search-icon { color: var(--accent); flex-shrink: 0; }
  .nav-center input {
    background: none;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    width: 100%;
  }
  .nav-center input::placeholder { color: var(--text-muted); font-weight: 400; }
  .nav-search-kbd {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }
  .kbd {
    background: var(--bg2);
    border: 1px solid var(--border2);
    border-radius: 5px;
    padding: 2px 7px;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    font-family: 'Instrument Sans', sans-serif;
  }
  .nav-clear {
    background: var(--bg2);
    border: 1px solid var(--border);
    cursor: pointer;
    color: var(--text-muted);
    display: none;
    padding: 4px 6px;
    border-radius: 6px;
    line-height: 0;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .nav-clear:hover { background: var(--border); color: var(--text); }
  .nav-clear.show { display: flex; }

  .nav-back-btn {
    display: none;
    align-items: center;
    gap: 7px;
    background: var(--surface);
    border: 1.5px solid var(--border);
    color: var(--text-dim);
    padding: 10px 18px;
    border-radius: 10px;
    cursor: pointer;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    box-shadow: var(--shadow-sm);
    transition: all 0.2s;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .nav-back-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-lt);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }
  .nav-back-btn.visible { display: flex; }


  #home-view, #chapter-view, #search-results-view, #product-view { display: none; }
  #home-view.active, #chapter-view.active, #search-results-view.active, #product-view.active { display: block; }

  /* ─── HOME ─── */
  .home-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 40px 32px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
  }
  .home-hero-text {}
  .home-eyebrow {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .home-title {
    font-family: 'Lora', serif;
    font-size: 40px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 10px;
  }
  .home-title em { font-style: italic; color: var(--accent); }
  .home-sub {
    font-size: 15px;
    color: var(--text-dim);
    max-width: 500px;
    line-height: 1.6;
  }

  .stats-strip {
    display: flex;
    gap: 2px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }
  .stat-pill {
    background: var(--surface);
    padding: 14px 22px;
    text-align: center;
    min-width: 90px;
  }
  .stat-pill .v {
    font-family: 'Lora', serif;
    font-size: 26px;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-pill .l {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    font-weight: 600;
  }

  /* Category grid */
  .section-label {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px 14px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 14px;
    padding: 0 40px 60px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .cat-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 22px;
    cursor: pointer;
    transition: all 0.22s ease;
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: hidden;
  }
  .cat-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(37,99,235,0.03), transparent);
    opacity: 0;
    transition: opacity 0.22s;
    pointer-events: none;
  }
  .cat-card:hover {
    border-color: var(--card-accent, var(--accent-mid));
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .cat-card:hover::after { opacity: 1; }

  .cat-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .cat-icon {
    width: 38px; height: 38px;
    background: var(--accent-lt);
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }
  .cat-count-badge {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 99px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
  }
  .cat-name {
    font-family: 'Lora', serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .cat-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-bottom: 14px;
    min-height: 28px;
  }
  .chip {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px 9px;
    font-size: 11px;
    font-weight: 500;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Instrument Sans', sans-serif;
  }
  .chip:hover {
    background: var(--accent-lt);
    border-color: var(--accent-mid);
    color: var(--accent);
  }
  .chip-more {
    color: var(--text-muted);
    background: transparent;
    border-color: transparent;
  }
  .cat-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .cat-browse-link {
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* ─── SEARCH RESULTS ─── */
  .results-wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px;
  }
  .results-banner {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 24px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: var(--shadow-sm);
  }
  .results-banner-text h2 {
    font-family: 'Lora', serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
  }
  .results-banner-text p { font-size: 13px; color: var(--text-muted); }

  .result-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: all 0.18s;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: var(--shadow-sm);
  }
  .result-card:hover {
    border-color: var(--accent-mid);
    box-shadow: var(--shadow-md);
    transform: translateX(3px);
  }
  .result-type-dot {
    width: 36px; height: 36px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .result-type-dot.assembly { background: var(--accent-lt); color: var(--accent); }
  .result-type-dot.component { background: var(--amber-lt); color: var(--amber); }
  .result-body { flex: 1; min-width: 0; }
  .result-pn {
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 3px;
    font-family: 'Instrument Sans', sans-serif;
  }
  .result-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .result-meta {
    font-size: 12px;
    color: var(--text-muted);
    display: flex;
    gap: 10px;
  }
  .result-badge {
    flex-shrink: 0;
    padding: 4px 12px;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .result-badge.assembly { background: var(--accent-lt); color: var(--accent); }
  .result-badge.component { background: var(--amber-lt); color: var(--amber); }
  .result-arrow { color: var(--text-muted); flex-shrink: 0; }

  .no-results {
    text-align: center;
    padding: 80px 20px;
    color: var(--text-muted);
  }
  .no-results .icon {
    width: 56px; height: 56px;
    background: var(--bg2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    color: var(--text-muted);
  }
  .no-results p { font-size: 15px; color: var(--text-dim); }
  .no-results p strong { color: var(--text); }

  /* ─── PRODUCT VIEW ─── */
  .product-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px;
  }

  .product-header-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 16px;
    padding: 28px 32px;
    margin-bottom: 20px;
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
  }
  .product-header-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), #60a5fa, #34d399);
  }
  .ph-breadcrumb {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .ph-breadcrumb span { color: var(--text-dim); }
  .ph-breadcrumb .sep { color: var(--border2); }
  .ph-breadcrumb .current { color: var(--text); font-weight: 500; }
  .ph-model {
    font-family: 'Lora', serif;
    font-size: 30px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 6px;
    line-height: 1.2;
  }
  .ph-pn {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ph-pn code {
    background: var(--accent-lt);
    color: var(--accent);
    padding: 2px 8px;
    border-radius: 5px;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 13px;
  }
  .ph-stats {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .ph-stat {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: var(--text-dim);
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 12px;
  }
  .ph-stat svg { color: var(--accent); }
  .ph-stat strong { color: var(--text); }

  /* BOM Table */
  .bom-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    padding: 0 2px;
  }
  .bom-title {
    font-family: 'Lora', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
  }
  .bom-count {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 99px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
  }

  .bom-table {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .bom-thead {
    display: grid;
    grid-template-columns: 130px 1fr 70px 75px;
    padding: 11px 20px;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
  }
  .bom-thead span {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-muted);
  }
  .bom-row {
    display: grid;
    grid-template-columns: 130px 1fr 70px 75px;
    padding: 12px 20px;
    border-bottom: 1px solid var(--border);
    align-items: center;
    transition: background 0.12s;
  }
  .bom-row:last-child { border-bottom: none; }
  .bom-row:hover { background: var(--surface2); }
  .bom-row:nth-child(even) { background: var(--surface2); }
  .bom-row:nth-child(even):hover { background: #f0ece6; }

  .bom-row-clickable { cursor: pointer; }
  .bom-row-clickable:hover { background: var(--accent-lt) !important; }
  .bom-row-clickable .bom-row-arrow {
    margin-left: 6px;
    opacity: 0;
    transform: translateX(-3px);
    transition: all 0.18s;
    color: var(--accent);
    vertical-align: -2px;
  }
  .bom-row-clickable:hover .bom-row-arrow { opacity: 1; transform: translateX(0); }

  .bom-row-sub {
    background: linear-gradient(90deg, rgba(234,88,12,0.05) 0%, transparent 100%);
    border-left: 3px solid #ea580c;
    padding-left: 17px;
  }
  .bom-row-sub:hover { background: linear-gradient(90deg, rgba(234,88,12,0.1) 0%, rgba(234,88,12,0.02) 100%) !important; }
  .bom-row-sub .bom-row-arrow { color: #ea580c; }

  .sub-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: 10px;
    padding: 2px 8px;
    background: #ffedd5;
    color: #c2410c;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    vertical-align: 1px;
    font-family: 'Instrument Sans', sans-serif;
  }
  .sub-badge svg { flex-shrink: 0; }

  .bom-pn {
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    font-family: 'Instrument Sans', sans-serif;
  }
  .bom-desc {
    font-size: 13px;
    color: var(--text);
    line-height: 1.4;
    padding-right: 16px;
  }
  .bom-uom {
    font-size: 11px;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .bom-qty {
    text-align: right;
    font-weight: 700;
    font-size: 14px;
    color: var(--green);
    font-family: 'Instrument Sans', sans-serif;
  }
  .bom-qty-wrap {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
  }

  /* highlight */
  .hl {
    background: #fef9c3;
    color: #92400e;
    border-radius: 2px;
    padding: 0 2px;
    font-weight: 600;
  }

  /* Animations */
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(12px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .cat-card { animation: fadeUp 0.4s ease both; }

  /* Scrollbar */
  ::-webkit-scrollbar { width:6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius:3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

  @media(max-width:768px) {
