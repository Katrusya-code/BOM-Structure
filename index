    card.innerHTML = `
      <div class="cat-card-top">
        <div class="cat-icon" style="background:${style.bg};color:${style.color}">${style.icon}</div>
        <span class="cat-count-badge">${models.length} models</span>
      </div>
      <div class="cat-name">${cat}</div>
      <div class="cat-chips">${chips}${more}</div>
      <div class="cat-footer">
        <span class="cat-browse-link" style="color:${style.color}">
          Browse all
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </div>
    `;
    card.style.setProperty('--card-accent', style.color);
    card.onclick = () => showCategory(chapterName, cat);
    grid.appendChild(card);
  });
}

function renderModelsAsCards(models, chapterName) {
  const grid = document.getElementById('categoriesGrid');
  grid.innerHTML = '';
  models.forEach((m, idx) => {
    const card = document.createElement('div');
    card.className = 'cat-card';
    card.style.animationDelay = (idx * 0.025) + 's';
    const style = catStyles[idx % catStyles.length];
    card.innerHTML = `
      <div class="cat-card-top">
        <div class="cat-icon" style="background:${style.bg};color:${style.color}">${style.icon}</div>
        <span class="cat-count-badge">${m.components.length} parts</span>
      </div>
      <div class="cat-name">${escapeHtml(m.model_name)}</div>
      <div style="font-size:12px;color:var(--text-muted);margin-bottom:14px;font-family:'Instrument Sans',sans-serif">PN <code style="background:var(--accent-lt);color:var(--accent);padding:1px 7px;border-radius:4px;font-weight:600">${m.part_number}</code></div>
      <div class="cat-footer">
        <span class="cat-browse-link" style="color:${style.color}">
          View build
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </div>
    `;
    card.style.setProperty('--card-accent', style.color);
    card.onclick = () => showProduct(m.part_number);
    grid.appendChild(card);
  });
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c]);
}

// ── Show a category page (list of models in a table) ──────────
function showCategory(chapterName, cat) {
  const chap = DATA[chapterName];
  if (!chap || chap.type !== 'categories') return;
  const models = chap.categories[cat];
  if (!models) return;
  pushHistory(() => showCategory(chapterName, cat));

  document.getElementById('bomTitle').textContent = 'Models in Category';
  document.getElementById('bomThead').innerHTML = `
    <span>Part Number</span><span>Model Name</span><span>Parts</span><span style="text-align:right"> </span>
  `;
  document.getElementById('productHeader').innerHTML = `
    <div class="ph-breadcrumb">
      <span onclick="goHome()" style="cursor:pointer">Home</span>
      <span class="sep">›</span>
      <span onclick="showChapter('${chapterName}')" style="cursor:pointer">${chapterName}</span>
      <span class="sep">›</span>
      <span class="current">${escapeHtml(cat)}</span>
    </div>
    <div class="ph-model">${escapeHtml(cat)}</div>
    <div class="ph-pn">&nbsp;</div>
    <div class="ph-stats">
      <div class="ph-stat">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        <span><strong>${models.length}</strong> model${models.length!==1?'s':''}</span>
      </div>
    </div>
  `;
  document.getElementById('compCount').textContent = `${models.length} models`;
  document.getElementById('compList').innerHTML = models.map(m => `
    <div class="bom-row" style="cursor:pointer" onclick="showProduct('${m.part_number}')">
      <div class="bom-pn">${m.part_number}</div>
      <div class="bom-desc" style="color:var(--accent);font-weight:500">${escapeHtml(m.model_name)}</div>
      <div class="bom-uom" style="color:var(--text-muted)">${m.components.length} parts</div>
      <div class="bom-qty" style="color:var(--text-muted)">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
      </div>
    </div>
  `).join('');
  showView('product-view');
  window.scrollTo(0, 0);
}

// ── Show single product (its BOM) ──────────────────────────────
function showProduct(pn) {
  const info = assemblyIndex[pn];
  if (!info) return;
  const { chapter, category, model } = info;

  pushHistory(() => showProduct(pn));

  document.getElementById('bomTitle').textContent = 'Bill of Materials';
  document.getElementById('bomThead').innerHTML = `
    <span>Part Number</span><span>Description</span><span>UoM</span><span style="text-align:right">Qty</span>
  `;

  // Breadcrumb depends on whether category exists
  let crumb = `<span onclick="goHome()" style="cursor:pointer">Home</span>
               <span class="sep">›</span>
               <span onclick="showChapter('${chapter}')" style="cursor:pointer">${chapter}</span>`;
  if (category) {
    crumb += `<span class="sep">›</span>
              <span onclick="showCategory('${chapter}','${category.replace(/'/g,"\\'")}')" style="cursor:pointer">${escapeHtml(category)}</span>`;
  }
  crumb += `<span class="sep">›</span>
            <span class="current">${escapeHtml(model.model_name)}</span>`;

  const contextLine = category ? `${chapter} · ${category}` : chapter;

  document.getElementById('productHeader').innerHTML = `
    <div class="ph-breadcrumb">${crumb}</div>
    <div class="ph-model">${escapeHtml(model.model_name)}</div>
    <div class="ph-pn">Assembly Part Number <code>${model.part_number}</code></div>
    <div class="ph-stats">
      <div class="ph-stat">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        <span><strong>${model.components.length}</strong> components</span>
      </div>
      <div class="ph-stat">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        <span>${escapeHtml(contextLine)}</span>
      </div>
    </div>
  `;

  document.getElementById('compCount').textContent = `${model.components.length} items`;

  document.getElementById('compList').innerHTML = model.components.map(c => {
    const isSubAssembly = !!assemblyIndex[c.part_number];
    const usedElsewhere = !isSubAssembly && componentIndex[c.part_number] && componentIndex[c.part_number].length > 1;
    const clickable = isSubAssembly || usedElsewhere;
    const handler = isSubAssembly
      ? `onclick="showProduct('${c.part_number}')"`
      : usedElsewhere
        ? `onclick="showComponentFromIndex('${c.part_number}')"`
        : '';
    const subBadge = isSubAssembly
      ? `<span class="sub-badge" title="Click to view sub-assembly breakdown">
           <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
           Sub-assembly
         </span>`
      : '';
    const arrow = clickable
      ? `<svg class="bom-row-arrow" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>`
      : '';
    return `
    <div class="bom-row ${clickable ? 'bom-row-clickable' : ''} ${isSubAssembly ? 'bom-row-sub' : ''}" ${handler}>
      <div class="bom-pn">${c.part_number}${arrow}</div>
      <div class="bom-desc">${escapeHtml(c.description)}${subBadge}</div>
      <div class="bom-uom">${c.uom.toUpperCase()}</div>
      <div class="bom-qty">${c.qty % 1 === 0 ? c.qty.toFixed(0) : c.qty}</div>
    </div>`;
  }).join('');

  showView('product-view');
  window.scrollTo(0, 0);
}

// ── Show component uses ────────────────────────────────────────
function showComponentUses(pn, desc, uses) {
  pushHistory(() => showComponentUses(pn, desc, uses));

  document.getElementById('bomTitle').textContent = 'Used In Assemblies';
  document.getElementById('bomThead').innerHTML = `
    <span>Assembly PN</span><span>Model / Location</span><span>UoM</span><span style="text-align:right">Qty</span>
  `;
  document.getElementById('productHeader').innerHTML = `
    <div class="ph-breadcrumb">
      <span onclick="goHome()" style="cursor:pointer">Home</span>
      <span class="sep">›</span>
      <span class="current">Component ${pn}</span>
    </div>
    <div class="ph-model">${escapeHtml(desc.length > 60 ? desc.slice(0,60)+'…' : desc)}</div>
    <div class="ph-pn">Component Part Number <code>${pn}</code></div>
    <div class="ph-stats">
      <div class="ph-stat">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        <span>Used in <strong>${uses.length}</strong> assembl${uses.length!==1?'ies':'y'}</span>
      </div>
    </div>
  `;
  document.getElementById('compCount').textContent = `${uses.length} assemblies`;
  document.getElementById('compList').innerHTML = uses.map(u => {
    const loc = u.category ? `${u.chapter} · ${u.category}` : u.chapter;
    return `
    <div class="bom-row" style="cursor:pointer" onclick="showProduct('${u.model.part_number}')">
      <div class="bom-pn">${u.model.part_number}</div>
      <div class="bom-desc" style="color:var(--accent);font-weight:500">${escapeHtml(u.model.model_name)}<span style="color:var(--text-muted);font-weight:400"> — ${escapeHtml(loc)}</span></div>
      <div class="bom-uom">${u.component.uom.toUpperCase()}</div>
      <div class="bom-qty">${u.component.qty % 1 === 0 ? u.component.qty.toFixed(0) : u.component.qty}</div>
    </div>`;
  }).join('');
  showView('product-view');
  window.scrollTo(0, 0);
}

// ── Switching views ────────────────────────────────────────────
function showView(id) {
  document.querySelectorAll('#home-view, #chapter-view, #search-results-view, #product-view').forEach(el => el.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.getElementById('homeBtn').classList.toggle('active-tab', id === 'home-view');
}

function goHome() {
  navHistory.length = 0;
  updateBackBtn();
  searchInput.value = '';
  navClear.classList.remove('show');
  document.getElementById('searchKbd').style.display = 'flex';
  document.getElementById('bomTitle').textContent = 'Bill of Materials';
  document.getElementById('bomThead').innerHTML = `<span>Part Number</span><span>Description</span><span>UoM</span><span style="text-align:right">Qty</span>`;
  showView('home-view');
  window.scrollTo(0, 0);
}
</script>
</body>
</html>
