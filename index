// ── Search ─────────────────────────────────────────────────────
const searchInput = document.getElementById('searchInput');
const navClear = document.getElementById('navClear');
let searchTimeout;

searchInput.addEventListener('input', () => {
  const hasVal = searchInput.value.length > 0;
  navClear.classList.toggle('show', hasVal);
  document.getElementById('searchKbd').style.display = hasVal ? 'none' : 'flex';
  clearTimeout(searchTimeout);
  searchTimeout = setTimeout(() => performSearch(searchInput.value.trim()), 180);
});
searchInput.addEventListener('keydown', e => {
  if (e.key === 'Escape') clearSearch();
});

document.addEventListener('keydown', e => {
  if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
    e.preventDefault();
    searchInput.focus();
    searchInput.select();
  }
});

// ── History stack ──────────────────────────────────────────────
const navHistory = [];

function pushHistory(fn) {
  navHistory.push(fn);
  updateBackBtn();
}

function goBack() {
  if (navHistory.length === 0) return;
  navHistory.pop();
  if (navHistory.length === 0) {
    goHome();
    return;
  }
  const prev = navHistory[navHistory.length - 1];
  navHistory.pop();
  prev();
}

function updateBackBtn() {
  document.getElementById('backBtn').classList.toggle('visible', navHistory.length > 0);
}

function clearSearch() {
  searchInput.value = '';
  navClear.classList.remove('show');
  document.getElementById('searchKbd').style.display = 'flex';
  goHome();
}

function performSearch(q) {
  if (!q) { goHome(); return; }
  const results = [];
  const ql = q.toLowerCase();

  for (const [pn, info] of Object.entries(assemblyIndex)) {
    if (pn.includes(q) || info.model.model_name.toLowerCase().includes(ql)) {
      results.push({ type: 'assembly', pn, ...info });
    }
  }
  for (const [pn, uses] of Object.entries(componentIndex)) {
    if (pn.includes(q) && !assemblyIndex[pn]) {
      results.push({ type: 'component', pn, desc: uses[0].component.description, uses });
    }
  }

  pushHistory(() => performSearch(q));
  showView('search-results-view');
  document.getElementById('resultsTitle').textContent = `Results for "${q}"`;
  document.getElementById('resultsSub').textContent = `${results.length} result${results.length !== 1 ? 's' : ''} found across assemblies and components`;

  const list = document.getElementById('resultsList');
  if (!results.length) {
    list.innerHTML = `<div class="no-results">
      <div class="icon"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div>
      <p>No parts found matching <strong>"${q}"</strong></p>
    </div>`;
    return;
  }

  window._compCache = {};

  list.innerHTML = results.map((r, idx) => {
    if (r.type === 'assembly') {
      const meta = r.category ? `${r.chapter} · ${r.category}` : r.chapter;
      return `<div class="result-card" onclick="showProduct('${r.pn}')">
        <div class="result-type-dot assembly">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        </div>
        <div class="result-body">
          <div class="result-pn">${hl(r.pn, q)}</div>
          <div class="result-name">${r.model.model_name}</div>
          <div class="result-meta"><span>${meta}</span><span>·</span><span>${r.model.components.length} components</span></div>
        </div>
        <span class="result-badge assembly">Assembly</span>
        <svg class="result-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
      </div>`;
    } else {
      window._compCache[idx] = { pn: r.pn, desc: r.desc, uses: r.uses };
      return `<div class="result-card" onclick="showComponentFromCache(${idx})">
        <div class="result-type-dot component">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        </div>
        <div class="result-body">
          <div class="result-pn">${hl(r.pn, q)}</div>
          <div class="result-name">${r.desc.length > 70 ? r.desc.slice(0,70)+'…' : r.desc}</div>
          <div class="result-meta"><span>Used in ${r.uses.length} assembl${r.uses.length!==1?'ies':'y'}</span><span>·</span><span>${r.uses[0].component.uom.toUpperCase()}</span></div>
        </div>
        <span class="result-badge component">Component</span>
        <svg class="result-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
      </div>`;
    }
  }).join('');
}

function showComponentFromCache(idx) {
  const c = window._compCache && window._compCache[idx];
  if (c) showComponentUses(c.pn, c.desc, c.uses);
}

function showComponentFromIndex(pn) {
  const uses = componentIndex[pn];
  if (!uses || !uses.length) return;
  showComponentUses(pn, uses[0].component.description, uses);
}

function hl(text, q) {
  if (!q) return text;
  const i = text.toLowerCase().indexOf(q.toLowerCase());
  if (i < 0) return text;
  return text.slice(0,i) + `<span class="hl">${text.slice(i, i+q.length)}</span>` + text.slice(i+q.length);
}

// ── Show a chapter (categories grid OR models list) ────────────
function showChapter(chapterName) {
  const chap = DATA[chapterName];
  if (!chap) return;
  pushHistory(() => showChapter(chapterName));

  const style = chapterStyles[chapterName] || { bg: '#dbeafe', color: '#2563eb' };
  const hero = document.getElementById('chapterHero');
  hero.style.setProperty('--ch-accent', style.color);
  hero.innerHTML = `
    <div class="ph-breadcrumb" style="margin-bottom:14px">
      <span onclick="goHome()" style="cursor:pointer">Home</span>
      <span class="sep">›</span>
      <span class="current">${chapterName}</span>
    </div>
    <div class="chapter-hero-eyebrow">Chapter</div>
    <h1>${chapterName}</h1>
    <p>${chap.tagline || ''}</p>
  `;

  if (chap.type === 'categories') {
    document.getElementById('chapterSectionLabel').textContent = 'Product Categories';
    document.getElementById('chapterSectionLabel').style.display = '';
    renderCategoriesGrid(chap.categories, chapterName);
  } else {
    document.getElementById('chapterSectionLabel').textContent = 'Models';
    document.getElementById('chapterSectionLabel').style.display = '';
    renderModelsAsCards(chap.models, chapterName);
  }
  showView('chapter-view');
  window.scrollTo(0, 0);
}

