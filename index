// ── Build indexes (chapter-aware) ──────────────────────────────
const assemblyIndex = {};   // pn -> { chapter, category, model } (category may be null for chapter=Multiboost)
const componentIndex = {};  // pn -> [{ chapter, category, model, component }]
let uniqueParts = new Set();
let totalModels = 0;

function indexModel(chapter, category, model) {
  assemblyIndex[model.part_number] = { chapter, category, model };
  uniqueParts.add(model.part_number);
  totalModels++;
  for (const comp of model.components) {
    uniqueParts.add(comp.part_number);
    if (!componentIndex[comp.part_number]) componentIndex[comp.part_number] = [];
    componentIndex[comp.part_number].push({ chapter, category, model, component: comp });
  }
}

for (const [chapName, chap] of Object.entries(DATA)) {
  if (chap.type === 'categories') {
    for (const [catName, models] of Object.entries(chap.categories)) {
      for (const m of models) indexModel(chapName, catName, m);
    }
  } else if (chap.type === 'models') {
    for (const m of chap.models) indexModel(chapName, null, m);
  }
}

document.getElementById('statChapters').textContent = Object.keys(DATA).length;
document.getElementById('statModels').textContent = totalModels;
document.getElementById('statParts').textContent = uniqueParts.size;

